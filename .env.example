# Server Configuration
PORT=3000
ENVIRONMENT=development

# Database
DB_URI=mongodb://localhost:27017

# JWT Configuration
ACCESS_TOKEN_PRIVATE_KEY=your-super-secret-access-token-key
REFRESH_TOKEN_PRIVATE_KEY=your-super-secret-refresh-token-key
ACCESS_TOKEN_MAX_AGE=900000
REFRESH_TOKEN_MAX_AGE=604800000

# AWS Configuration (optional - for email/file upload)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# Email Configuration (optional)
EMAIL_FROM=noreply@yourdomain.com

# Twilio SMS (optional)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890
